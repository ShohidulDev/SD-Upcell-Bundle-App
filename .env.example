SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=read_products,write_products
SHOPIFY_APP_URL=https://your-app.vercel.app
PORT=3000

# Vercel Postgres / Supabase / Neon connection string.
# Vercel's filesystem is ephemeral, so SQLite will not persist sessions.
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
